# Elixir4vet Production Environment Template
# Copy to /etc/elixir4vet/.env.prod and customize

# ===========================================
# Phoenix Configuration
# ===========================================
PHX_SERVER=true
PHX_HOST=elixir4vet.example.com
PORT=4000

# ===========================================
# Database Configuration
# ===========================================
DATABASE_PATH=/opt/elixir4vet/data/elixir4vet_prod.db
POOL_SIZE=10

# ===========================================
# Security
# ===========================================
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=CHANGE_ME_WITH_OUTPUT_FROM_MIX_PHX_GEN_SECRET

# ===========================================
# Email Configuration (Swoosh)
# ===========================================
MAIL_FROM=noreply@elixir4vet.example.com

# Example: Mailgun
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_API_KEY=your-api-key

# Example: Sendgrid
# SENDGRID_API_KEY=your-api-key

# Example: Resend
# RESEND_API_KEY=your-api-key

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info

# ===========================================
# Environment
# ===========================================
MIX_ENV=prod

# ===========================================
# Optional: DNS Clustering
# (for distributed Erlang nodes)
# ===========================================
# DNS_CLUSTER_QUERY=elixir4vet.query.consul
# RELEASE_DISTRIBUTION=name
# RELEASE_NODE=elixir4vet@127.0.0.1

# ===========================================
# Optional: Custom Application Settings
# ===========================================
# APP_NAME=Elixir4vet
# TIMEZONE=UTC
